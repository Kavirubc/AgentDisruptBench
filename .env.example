# ==============================================================
# AgentDisruptBench — Environment Variables
# ==============================================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# These variables are optional. The benchmark runs entirely
# with built-in mock tools by default. Only needed for:
#   - LLM-powered task generation (OPENAI_API_KEY)
#   - Framework adapter tests that hit real APIs
# ==============================================================

# --- LLM / OpenAI (for evaluation runners and task generation) ---
# Required when using: openai_runner, langchain_runner, autogen_runner, crewai_runner
# Not needed for: simple_runner (no LLM)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- LiteLLM (optional, alternative to OpenAI) ---
# LITELLM_API_KEY=
# LITELLM_MODEL=

# --- Benchmark Configuration ---
# AGENTDISRUPTBENCH_SEED=42
# AGENTDISRUPTBENCH_LOG_LEVEL=INFO
# AGENTDISRUPTBENCH_OUTPUT_DIR=results

# --- Track B: Network Layer (Docker Compose) ---
# ENVOY_ADMIN_PORT=9901
# EXT_PROC_PORT=50051
# UPSTREAM_HOST=host.docker.internal
# UPSTREAM_PORT=443
