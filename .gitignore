# ==============================================================
# AgentDisruptBench — .gitignore
# ==============================================================

# ----- Python -----
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ----- Testing -----
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ----- Results / Outputs -----
# Legacy scattered output dirs (superseded by runs/)
results/
evaluation_results/
legacy_traces/

# Track curated run outputs — runs/ is intentionally NOT ignored
# Only commit the summary-level files: results.csv, results.json,
# summary.json, report.md, and run logs. Exclude verbose traces.
task_logs/
run_log.jsonl

# Ignore loose root-level log files only
*.log
# But allow log files inside runs/ directories
!runs/**/*.log

# ----- Environment -----
.env
.env.local
.env.*.local

# ----- Docker (Track B) -----
network/certs/*.pem
network/certs/*.key

# ----- Paper (LaTeX) -----
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.pdf
paper/*.toc

# ----- OS -----
Thumbs.db
.DS_Store
