# ==============================================================
# AgentDisruptBench — .gitignore
# ==============================================================

# ----- Python -----
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ----- Testing -----
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ----- Results / Outputs -----
# Legacy scattered output dirs (now in legacy_traces/)
results/
evaluation_results/

# Ignore consolidated run outputs
runs/
legacy_traces/

# Ignore loose log files but allow .jsonl inside runs/ and legacy_traces/
*.log

# ----- Environment -----
.env
.env.local
.env.*.local

# ----- Docker (Track B) -----
network/certs/*.pem
network/certs/*.key

# ----- OS -----
Thumbs.db
.DS_Store
